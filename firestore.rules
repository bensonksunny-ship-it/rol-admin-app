rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function getUserData() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return u != null && u.data != null ? u.data : {};
    }
    function getUserRole() {
      return isSignedIn() ? getUserData().get('role', null) : null;
    }
    function getGlobalRole() {
      return isSignedIn() ? getUserData().get('globalRole', null) : null;
    }
    function tokenGlobalRole() {
      return isSignedIn() ? request.auth.token.globalRole : null;
    }
    function userDepartment() {
      return isSignedIn() ? getUserData().get('department', null) : null;
    }
    function userDepartments() {
      return isSignedIn() ? getUserData().get('departments', []) : [];
    }
    function isFullAccess() {
      // Super admin override (prioritize Auth custom claim), with legacy fallback.
      return isSignedIn() && (
        tokenGlobalRole() == 'FOUNDER' ||
        getGlobalRole() == 'FOUNDER' ||
        getUserRole() == 'Founder' ||
        getUserRole() == 'founder'
      );
    }
    function canAccessDept(departmentId) {
      return isSignedIn() && (
        isFullAccess() ||
        userDepartment() == departmentId ||
        (departmentId in userDepartments())
      );
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && (isFullAccess() || request.auth.uid == userId);
    }

    // Audit logs: everyone may write; only Founder may read
    match /audit_logs/{logId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && isFullAccess();
      allow update, delete: if false;
    }

    // Department assignments (e.g. D Light Assign tab)
    match /department_assignments/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /departments/{departmentId} {
      allow read: if isSignedIn();
      allow write: if isFullAccess();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_team_members/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_sub_departments/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_children/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_child_attendance/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_events/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_planning_notes/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_updates/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /department_entries/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /delight_visitors/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept('D Light'));
      allow create, update, delete: if isSignedIn() && (isFullAccess() || canAccessDept('D Light'));
    }

    match /dlight_sub_departments/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept('D Light'));
      allow create, update, delete: if isSignedIn() && (isFullAccess() || canAccessDept('D Light'));
    }

    match /sunday_program/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isFullAccess() || canAccessDept('Sunday Ministry'));
    }

    match /sunday_program_log/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isFullAccess() || canAccessDept('Sunday Ministry'));
    }

    match /cell_groups/{cellId} {
      // Some legacy docs may not have a consistent `department` field.
      // If a user has access to the Cell department, allow access to cell groups.
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept('Cell'));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept('Cell'));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept('Cell'));
    }

    match /cell_groups/{cellId}/members/{memberId} {
      allow read, write: if isSignedIn() && (isFullAccess() || canAccessDept('Cell'));
    }
    match /cell_groups/{cellId}/program_items/{itemId} {
      allow read: if isSignedIn() && (isFullAccess() || isCellDirector() || (canAccessDept('Cell') && userLinkedCellId() == cellId));
      allow create, update, delete: if isSignedIn() && (isFullAccess() || (canAccessDept('Cell') && userLinkedCellId() == cellId));
    }
    match /cell_program_log/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cell_back_to_bible/{docId} {
      allow read, write: if request.auth != null;
    }
    match /cell_member_pending_changes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Prefer cellGroupId when set; otherwise cellId (leader’s linked cell for report edits).
    function userLinkedCellId() {
      let d = getUserData();
      let g = d.get('cellGroupId', null);
      return g != null && g != '' ? g : d.get('cellId', null);
    }
    function isCellDirector() {
      return isSignedIn() && userDepartment() == 'Cell' && getUserRole() == 'Director';
    }
    match /cell_reports/{reportId} {
      allow read: if isSignedIn() && (isFullAccess() || isCellDirector() || (canAccessDept('Cell') && resource.data.cellId == userLinkedCellId()));
      allow create: if isSignedIn() && (isFullAccess() || (canAccessDept('Cell') && request.resource.data.cellId == userLinkedCellId()));
      allow update, delete: if isSignedIn() && (isFullAccess() || (canAccessDept('Cell') && resource.data.cellId == userLinkedCellId()));
    }
    match /cell_reports/{reportId}/attendees/{attendeeId} {
      allow read: if isSignedIn() && (isFullAccess() || isCellDirector() || (canAccessDept('Cell') && get(/databases/$(database)/documents/cell_reports/$(reportId)).data.get('cellId', '') == userLinkedCellId()));
      allow create, update, delete: if isSignedIn() && (isFullAccess() || (canAccessDept('Cell') && get(/databases/$(database)/documents/cell_reports/$(reportId)).data.get('cellId', '') == userLinkedCellId()));
    }

    match /caring_members/{docId} {
      allow read, write: if isSignedIn() && (isFullAccess() || userDepartment() == 'Caring');
    }

    match /cell_attendance/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
      allow create: if isSignedIn() && (isFullAccess() || canAccessDept(request.resource.data.department));
      allow update, delete: if isSignedIn() && (isFullAccess() || canAccessDept(resource.data.department));
    }

    match /finance_budget/{docId} {
      allow read: if isSignedIn() && (isFullAccess() || !('department' in resource.data) || resource.data.department == userDepartment());
      allow create: if isSignedIn() && (isFullAccess() || !('department' in request.resource.data) || request.resource.data.department == userDepartment());
      allow update, delete: if isSignedIn() && (isFullAccess() || !('department' in resource.data) || resource.data.department == userDepartment());
    }

    match /pastor_department_remarks/{docId} {
      allow read, write: if isSignedIn();
    }

    match /pastor_department_updates/{docId} {
      allow read, write: if isSignedIn();
    }

    match /finance_income/{docId} {
      allow read, write: if isSignedIn();
    }

    match /finance_expense/{docId} {
      allow read, write: if isSignedIn();
    }

    match /attendance/{docId} {
      allow read, write: if isSignedIn();
    }

    match /sunday_plans/{docId} {
      allow read, write: if isSignedIn();
    }

    match /worship_budget_items/{docId} {
      allow read, write: if isSignedIn();
    }

    match /worship_team_members/{docId} {
      allow read, write: if isSignedIn();
    }

    match /worship_schedule/{docId} {
      allow read, write: if isSignedIn();
    }

    match /sunday_ministry_team_members/{docId} {
      allow read, write: if isSignedIn();
    }

    match /sunday_ministry_budget_items/{docId} {
      allow read, write: if isSignedIn();
    }

    match /sunday_reports/{docId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && (isFullAccess() || userDepartment() == 'Sunday Ministry');
    }
  }
}
